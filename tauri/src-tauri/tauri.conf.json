{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oh-my-lan",
  "version": "0.1.0",
  "identifier": "com.zhiying8710.oh-my-lan",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "oh-my-lan",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/omlctl"
    ],
    "category": "DeveloperTool",
    "shortDescription": "oh-my-lan desktop management",
    "longDescription": "Desktop UI for oh-my-lan: list / publish / forward services and start-stop the local daemon."
  }
}
